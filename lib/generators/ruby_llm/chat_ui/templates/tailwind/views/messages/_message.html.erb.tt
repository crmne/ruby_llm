<%# Intentional minimal domain tweak over scaffold: role + streamed content readability. -%>
<%% role = <%= message_model_name.demodulize.underscore %>.role.to_s %>
<%% is_tool_call = <%= message_model_name.demodulize.underscore %>.tool_call? %>
<%% container_classes = if role == "user"
                         "bg-blue-50"
                       elsif role == "assistant" && !is_tool_call
                         "bg-green-50"
                       else
                         "bg-gray-50 border border-gray-200"
                       end %>
<%% badge_classes = if role == "user"
                     "bg-blue-100 text-blue-700"
                   elsif role == "assistant" && !is_tool_call
                     "bg-green-100 text-green-700"
                   else
                     "bg-gray-200 text-gray-700"
                   end %>
<%% role_label = if is_tool_call
                   "Tool Call"
                 elsif role.present?
                   role.capitalize
                 else
                   "Message"
                 end %>

<div id="<%= message_variable_name %>_<%%= <%= message_model_name.demodulize.underscore %>.id %>" class="w-full sm:w-auto my-5 space-y-3 rounded-md px-3 py-2 <%%= container_classes %>">
  <div>
    <span class="inline-block rounded px-2 py-0.5 text-xs font-medium <%%= badge_classes %>">
      <%%= role_label %>
    </span>
  </div>

  <div>
    <div id="<%= message_variable_name %>_<%%= <%= message_model_name.demodulize.underscore %>.id %>_content" class="whitespace-pre-wrap"><%%= <%= message_model_name.demodulize.underscore %>.content %></div>
  </div>

  <%% if <%= message_model_name.demodulize.underscore %>.tool_call? %>
    <%%= render "<%= message_model_name.underscore.pluralize %>/tool_calls", <%= message_model_name.demodulize.underscore %>: <%= message_model_name.demodulize.underscore %> %>
  <%% end %>

  <div>
    <span class="text-sm text-gray-600"><%%= <%= message_model_name.demodulize.underscore %>.created_at&.strftime("%I:%M %p") %></span>
  </div>
</div>
