<%% error_message = tool_result_error_message(message) %>
<%% tool_name = tool_result_name(message) %>
<%% if error_message.present? %>
  <%%= render "<%= message_model_name.underscore.pluralize %>/error",
    message: message,
    title: "Tool Result Error",
    error_message: error_message %>
<%% else %>
  <div id="message_<%%= message.id %>" class="w-full sm:w-auto my-5 space-y-3 rounded-md px-3 py-2 bg-gray-50 border border-gray-200">
    <div>
      <span class="inline-block rounded px-2 py-0.5 text-xs font-medium bg-gray-200 text-gray-700">
        Tool<%% if tool_name.present? %>: <%%= tool_name %><%% end %>
      </span>
    </div>

    <pre class="whitespace-pre-wrap text-gray-700 text-sm overflow-x-auto"><%%= message.content.presence || "(no output)" %></pre>

    <div>
      <span class="text-sm text-gray-600"><%%= message.created_at&.strftime("%I:%M %p") %></span>
    </div>
  </div>
<%% end %>
