<div id="message_<%%= message.id %>" class="message"
     style="margin-bottom: 20px; padding: 10px; border-left: 3px solid #007bff;">
  <div style="font-weight: bold; margin-bottom: 5px;">User</div>
  <div id="message_<%%= message.id %>_content" style="white-space: pre-wrap;"><%%= message.content %></div>
  <div style="font-size: 0.85em; color: #666; margin-top: 5px;">
    <%%= message.created_at&.strftime("%I:%M %p") %>
  </div>
</div>
