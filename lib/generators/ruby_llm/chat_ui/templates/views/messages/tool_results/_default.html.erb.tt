<%% error_message = tool_result_error_message(message) %>
<%% tool_name = tool_result_name(message) %>
<%% if error_message.present? %>
  <%%= render "<%= message_model_name.underscore.pluralize %>/error",
    message: message,
    title: "Tool Result Error",
    error_message: error_message %>
<%% else %>
  <div id="message_<%%= message.id %>" class="message"
       style="margin-bottom: 20px; padding: 10px; border-left: 3px solid #6b7280; background: #f9fafb;">
    <div style="font-weight: bold; margin-bottom: 5px;">
      Tool<%% if tool_name.present? %>: <%%= tool_name %><%% end %>
    </div>
    <pre style="white-space: pre-wrap; margin: 0;"><%%= message.content.presence || "(no output)" %></pre>
    <div style="font-size: 0.85em; color: #666; margin-top: 5px;">
      <%%= message.created_at&.strftime("%I:%M %p") %>
    </div>
  </div>
<%% end %>
